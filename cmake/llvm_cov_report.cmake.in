set(HFILE_COVERAGE_ROOT "@CMAKE_BINARY_DIR@/coverage")
set(HFILE_COVERAGE_RAW_DIR "${HFILE_COVERAGE_ROOT}/raw")
set(HFILE_COVERAGE_HTML_DIR "${HFILE_COVERAGE_ROOT}/html")
set(HFILE_COVERAGE_PROFDATA "${HFILE_COVERAGE_ROOT}/hfilesdk.profdata")
set(HFILE_COVERAGE_SUMMARY "${HFILE_COVERAGE_ROOT}/summary.txt")
set(HFILE_COVERAGE_ARTIFACTS_ROOT "@CMAKE_BINARY_DIR@/artifacts")
set(HFILE_COVERAGE_ARTIFACTS_HTML_DIR "${HFILE_COVERAGE_ARTIFACTS_ROOT}/coverage-html")
set(HFILE_COVERAGE_ARTIFACTS_SUMMARY "${HFILE_COVERAGE_ARTIFACTS_ROOT}/coverage-summary.txt")
set(HFILE_COVERAGE_ARTIFACTS_PROFDATA "${HFILE_COVERAGE_ARTIFACTS_ROOT}/coverage.profdata")
set(HFILE_COVERAGE_IGNORE_REGEX "(^/Applications/|^/Library/|^/usr/|.*/\\.conda-hfilesdk/|.*/build/)")

include("@CMAKE_BINARY_DIR@/hfile_coverage_targets.cmake")

file(REMOVE_RECURSE "${HFILE_COVERAGE_ROOT}")
file(REMOVE_RECURSE "${HFILE_COVERAGE_ARTIFACTS_ROOT}")
file(MAKE_DIRECTORY "${HFILE_COVERAGE_RAW_DIR}")
file(MAKE_DIRECTORY "${HFILE_COVERAGE_ARTIFACTS_ROOT}")

execute_process(
  COMMAND "@CMAKE_COMMAND@" -E env
          "LLVM_PROFILE_FILE=${HFILE_COVERAGE_RAW_DIR}/%m-%p.profraw"
          "@CMAKE_CTEST_COMMAND@" --output-on-failure @HFILE_COVERAGE_CTEST_ARGS@
  WORKING_DIRECTORY "@CMAKE_BINARY_DIR@"
  RESULT_VARIABLE HFILE_CTEST_STATUS
)

if(NOT HFILE_CTEST_STATUS EQUAL 0)
  message(FATAL_ERROR "ctest failed while collecting coverage")
endif()

file(GLOB_RECURSE HFILE_PROFRAW_FILES "${HFILE_COVERAGE_RAW_DIR}/*.profraw")

if(NOT HFILE_PROFRAW_FILES)
  message(FATAL_ERROR "No .profraw files were generated")
endif()

set(HFILE_PROFDATA_COMMAND "@HFILE_LLVM_PROFDATA_EXECUTABLE@" merge -sparse)
list(APPEND HFILE_PROFDATA_COMMAND ${HFILE_PROFRAW_FILES})
list(APPEND HFILE_PROFDATA_COMMAND -o "${HFILE_COVERAGE_PROFDATA}")

execute_process(
  COMMAND ${HFILE_PROFDATA_COMMAND}
  RESULT_VARIABLE HFILE_PROFDATA_STATUS
)

if(NOT HFILE_PROFDATA_STATUS EQUAL 0)
  message(FATAL_ERROR "llvm-profdata merge failed")
endif()

list(LENGTH HFILE_COVERAGE_OBJECTS HFILE_COVERAGE_OBJECT_COUNT)
if(HFILE_COVERAGE_OBJECT_COUNT EQUAL 0)
  message(FATAL_ERROR "No coverage objects were registered")
endif()

list(GET HFILE_COVERAGE_OBJECTS 0 HFILE_COVERAGE_MAIN_OBJECT)
if(HFILE_COVERAGE_OBJECT_COUNT GREATER 1)
  list(REMOVE_AT HFILE_COVERAGE_OBJECTS 0)
endif()

set(HFILE_COVERAGE_OBJECT_ARGS)
foreach(HFILE_OBJECT IN LISTS HFILE_COVERAGE_OBJECTS)
  list(APPEND HFILE_COVERAGE_OBJECT_ARGS "-object=${HFILE_OBJECT}")
endforeach()

set(HFILE_REPORT_COMMAND
  "@HFILE_LLVM_COV_EXECUTABLE@" report
  "${HFILE_COVERAGE_MAIN_OBJECT}"
  "-instr-profile=${HFILE_COVERAGE_PROFDATA}"
  "-ignore-filename-regex=${HFILE_COVERAGE_IGNORE_REGEX}"
)
list(APPEND HFILE_REPORT_COMMAND ${HFILE_COVERAGE_OBJECT_ARGS})

execute_process(
  COMMAND ${HFILE_REPORT_COMMAND}
  RESULT_VARIABLE HFILE_REPORT_STATUS
  OUTPUT_FILE "${HFILE_COVERAGE_SUMMARY}"
)

if(NOT HFILE_REPORT_STATUS EQUAL 0)
  message(FATAL_ERROR "llvm-cov report failed")
endif()

set(HFILE_SHOW_COMMAND
  "@HFILE_LLVM_COV_EXECUTABLE@" show
  "${HFILE_COVERAGE_MAIN_OBJECT}"
  "-instr-profile=${HFILE_COVERAGE_PROFDATA}"
  "-ignore-filename-regex=${HFILE_COVERAGE_IGNORE_REGEX}"
  -format=html
  "-output-dir=${HFILE_COVERAGE_HTML_DIR}"
  -show-line-counts-or-regions
)
list(APPEND HFILE_SHOW_COMMAND ${HFILE_COVERAGE_OBJECT_ARGS})

execute_process(
  COMMAND ${HFILE_SHOW_COMMAND}
  RESULT_VARIABLE HFILE_SHOW_STATUS
)

if(NOT HFILE_SHOW_STATUS EQUAL 0)
  message(FATAL_ERROR "llvm-cov show failed")
endif()

file(COPY "${HFILE_COVERAGE_HTML_DIR}" DESTINATION "${HFILE_COVERAGE_ARTIFACTS_ROOT}")
file(RENAME
  "${HFILE_COVERAGE_ARTIFACTS_ROOT}/html"
  "${HFILE_COVERAGE_ARTIFACTS_HTML_DIR}")
file(COPY_FILE
  "${HFILE_COVERAGE_SUMMARY}"
  "${HFILE_COVERAGE_ARTIFACTS_SUMMARY}"
  ONLY_IF_DIFFERENT)
file(COPY_FILE
  "${HFILE_COVERAGE_PROFDATA}"
  "${HFILE_COVERAGE_ARTIFACTS_PROFDATA}"
  ONLY_IF_DIFFERENT)

message(STATUS "Coverage summary: ${HFILE_COVERAGE_SUMMARY}")
message(STATUS "Coverage HTML: ${HFILE_COVERAGE_HTML_DIR}/index.html")
message(STATUS "Coverage artifacts: ${HFILE_COVERAGE_ARTIFACTS_ROOT}")
